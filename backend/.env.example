MONGO_URL=mongodb://localhost:27017
DB_NAME=25th_infantry_division
JWT_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_SECRET
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Frontend origin — used for CORS and OAuth redirect URLs.
# Set to the public URL of your frontend (no trailing slash).
# FRONTEND_URL=https://yourdomain.com

# Additional allowed CORS origins (comma-separated), if the frontend is
# served from more than one origin.  FRONTEND_URL is always included
# automatically, so you usually don't need this.
# CORS_ORIGINS=https://www.yourdomain.com,https://staging.yourdomain.com

# Set to false when running the backend over plain HTTP (e.g. local dev).
# Must be true in production (HTTPS).
COOKIE_SECURE=false

# Optional — Persistent upload directory.
# Set this to a path OUTSIDE the git repo so uploaded images survive
# git pull / reset / redeploy.  When unset, defaults to <backend>/uploads.
# UPLOAD_DIR=/opt/data/uploads

# Optional — Discord OAuth2 (omit to disable Discord login)
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=
# DISCORD_REDIRECT_URI=https://yourdomain.com/api/auth/discord/callback

# Optional — Valyu API (powers Global Threat Map intelligence features)
# Get your API key at: https://platform.valyu.ai
# VALYU_API_KEY=valyu_your_api_key_here

# Valyu caching / rate-limiting (optional – sensible defaults are used)
# VALYU_CACHE_TTL_MINUTES=30
# VALYU_EVENT_REFRESH_MINUTES=10
# VALYU_RATE_LIMIT_SECONDS=30
# VALYU_COUNTRY_CACHE_HOURS=24

# Optional — OpenAI API key (powers research agent and supplemental threat intel)
# OPENAI_API_KEY=sk-...

# Optional — ADS-B / Military Aircraft Tracking
# Cache duration in seconds for ADS-B API responses (default: 15)
# ADSB_CACHE_SECONDS=15
# OpenSky Network OAuth2 credentials (client_credentials grant)
# Register at https://opensky-network.org → create API client to get these:
# OPENSKY_CLIENT_ID=your-client-id
# OPENSKY_CLIENT_SECRET=your-client-secret
# Minimum seconds between OpenSky API calls (default: 10, respects rate limits)
# OPENSKY_MIN_INTERVAL_S=10

# ─── WorldMonitor Data Pipeline Configuration ─────────────────────────────
# These variables configure the data sources that mirror the worldmonitor-
# bayesian overlay system (https://github.com/swatfa/worldmonitor-bayesian).

# GDELT — Global Database of Events, Language, and Tone (no auth required)
# Provides real-time news intelligence across 6 topic areas.
# GDELT_API_URL=https://api.gdeltproject.org/api/v2/doc/doc

# FRED — Federal Reserve Economic Data
# Provides economic indicators (CPI, unemployment, VIX, yield curve, etc.)
# Register at: https://fred.stlouisfed.org/docs/api/api_key.html
# FRED_API_KEY=your-fred-api-key

# Polymarket — Prediction Markets (no auth required)
# Provides geopolitical prediction market data.
# POLYMARKET_API_URL=https://gamma-api.polymarket.com/events

# ACLED — Armed Conflict Location & Event Data
# Provides protest, riot, and civil unrest data worldwide.
# Register at: https://developer.acleddata.com/
# ACLED_ACCESS_TOKEN=your-acled-token
# ACLED_EMAIL=your-registered-email@example.com

# NWS Weather — National Weather Service alerts (no auth required)
# NWS requires a valid User-Agent with contact email. Set this for production.
# NWS_USER_AGENT=(25vid-worldmonitor, contact@yourdomain.com)

# Mapbox — Map rendering for Globe and Overlay views
# MAPBOX_TOKEN is set in the frontend .env; this is for backend geocoding if needed.
# MAP_TILE_URL=https://api.mapbox.com/styles/v1/mapbox/dark-v11/tiles/{z}/{x}/{y}

# AI Classification — Enhanced event categorization using OpenAI
# Uses the same OPENAI_API_KEY above. Set to 'true' to enable.
# AI_CLASSIFICATION_ENABLED=false

# ─── Docker-specific (only needed when using docker-compose.yml) ────
# When using Docker Compose, MONGO_URL is overridden to mongodb://mongo:27017
# REACT_APP_BACKEND_URL=        # leave empty for same-origin (Nginx proxy)
# REACT_APP_MAPBOX_TOKEN=pk.xxx # Mapbox GL token for map features
# HOST_PORT=80                  # host port to expose the frontend on
