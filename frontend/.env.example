REACT_APP_BACKEND_URL=http://localhost:8001
REACT_APP_MAPBOX_TOKEN=pk.your_mapbox_public_token_here
# REACT_APP_MAP_STYLE=mapbox://styles/mapbox/dark-v11
# REACT_APP_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
# REACT_APP_MAP_ATTRIBUTION=&copy; OpenStreetMap contributors
# REACT_APP_DEFAULT_MAP_CENTER_LAT=20
# REACT_APP_DEFAULT_MAP_CENTER_LNG=0
# REACT_APP_DEFAULT_MAP_ZOOM=2

# World Monitor Intelligence Overlay (required for the Overlay map view)
# Point this at the running worldmonitor instance.
# Local dev:  http://localhost:3000
# Production: /worldmonitor/  (served from the same Nginx, built automatically)
REACT_APP_WORLDMONITOR_URL=/worldmonitor/

# WorldMonitor Data Pipeline endpoints (served via backend API)
# These endpoints provide data from GDELT, USGS, NWS, FRED, Polymarket, ACLED.
# No additional frontend config needed — they use REACT_APP_BACKEND_URL + /api/worldmonitor/*
