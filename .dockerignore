# Ignore git history and metadata
.git
.gitignore

# Ignore node_modules — each stage installs its own
frontend/node_modules
worldmonitor/node_modules
backend/__pycache__
backend/.venv

# Ignore local build artifacts
frontend/build
worldmonitor/dist

# Ignore environment / secret files
.env
.env.*
**/.env
**/.env.*

# Ignore logs
*.log

# Ignore docs / non-build files
*.md
LICENSE
