# WorldMonitor [Black Swan Edition] — Environment Configuration
# See API_CONFIGURATION.md for detailed setup instructions.

# ─── Required API Keys ──────────────────────────────────────────────────────
# Finnhub — Stock market data (register at https://finnhub.io/)
FINNHUB_API_KEY=your-finnhub-api-key

# FRED — Federal Reserve Economic Data (register at https://fred.stlouisfed.org/)
FRED_API_KEY=your-fred-api-key

# ─── Optional API Keys ──────────────────────────────────────────────────────
# ACLED — Armed Conflict Location & Event Data
# ACLED_EMAIL=your-email@example.com
# ACLED_ACCESS_TOKEN=your-acled-token

# Cloudflare — Internet outage tracking
# CLOUDFLARE_API_TOKEN=your-cloudflare-token

# AISStream — Maritime vessel tracking (register at https://aisstream.io/)
# AISSTREAM_API_KEY=your-aisstream-key

# ─── WebSocket Relay URLs ───────────────────────────────────────────────────
# AIS relay (for maritime vessel tracking)
# VITE_WS_RELAY_URL=ws://localhost:3004

# OpenSky relay (for military aircraft tracking)
# VITE_OPENSKY_RELAY_URL=ws://localhost:3005

# ─── No-Auth APIs (these work without keys) ─────────────────────────────────
# GDELT: https://api.gdeltproject.org/api/v2/doc/doc
# USGS Earthquakes: https://earthquake.usgs.gov/earthquakes/feed/v1.0/
# NWS Weather: https://api.weather.gov/alerts/active
# Polymarket: https://gamma-api.polymarket.com/events
# Yahoo Finance: via Vercel proxy
# CoinGecko: via Vercel proxy
